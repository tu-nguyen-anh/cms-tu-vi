<% const title='Đổi mật khẩu' %>
<%- include('partials/header') %>
<h1>Đổi mật khẩu</h1>
<% if (error) { %><div class="flash flash-error"><%= error %></div><% } %>
<% if (success) { %><div class="flash flash-success"><%= success %></div><% } %>
<form method="POST" action="/change-password" class="form-card" style="max-width:480px">
  <label>Mật khẩu hiện tại</label>
  <input name="currentPassword" type="password" required>
  <label>Mật khẩu mới (≥ 8 ký tự)</label>
  <input name="newPassword" type="password" required>
  <label>Xác nhận mật khẩu mới</label>
  <input name="confirmPassword" type="password" required>
  <button class="btn btn-primary" type="submit">Cập nhật</button>
</form>
<%- include('partials/footer') %>
